# Dependency directories
node_modules/
**/node_modules/

# Environment variables (secrets - never commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
# Allow .env.production (non-secret public API URLs only)
!.env.production
!**/.env.production

# Production builds
dist/
**/dist/
build/
**/build/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System files
.DS_Store
Thumbs.db
